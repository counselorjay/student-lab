# Student Lab gateway configuration. Copy to .env and edit.

# Admin email matched against Cf-Access-Authenticated-User-Email
ADMIN_EMAIL=jay@counselorjay.com

# Backend Ollama hosts (Tailnet IPs). Empty means "skip this backend".
# M3 Pro is deliberately excluded from the student fleet (Jay 2026-04-24, daily driver).
BACKEND_M5_MAX=http://100.83.184.88:11434
BACKEND_M5_PRO=http://100.120.197.64:11434

# SQLite path (relative to gateway/ root). data/ is gitignored.
DB_PATH=data/lab.db

# Health probe interval (seconds, per Felix ROUTING.md §2.1: 15s)
HEALTH_PROBE_INTERVAL=15
HEALTH_PROBE_TIMEOUT=3
HEALTH_FAIL_THRESHOLD=3

# Default per-user limits applied when creating users via admin API
DEFAULT_DAILY_REQUEST_LIMIT=200
DEFAULT_DAILY_TOKEN_LIMIT=500000

# Request timeout when proxying to a backend (seconds)
PROXY_TIMEOUT=600

# Path to the dashboard build output. The gateway tries dist/ first, then root.
DASHBOARD_DIR=../dashboard
